<Window x:Class="Buddy.Windows.Tray.FloatingPanelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Buddy"
        Width="320"
        Height="620"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowActivated="False"
        ShowInTaskbar="False"
        Topmost="True">
    <Window.Resources>
        <Style x:Key="PanelButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2B7CFF" />
            <Setter Property="BorderBrush" Value="#5294FF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Height" Value="42" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#3B86FF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#1E66D8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#14171C"
            BorderBrush="#2E333D"
            BorderThickness="1"
            CornerRadius="18"
            Padding="20"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="26"
                              Color="#000000"
                              Opacity="0.42"
                              ShadowDepth="8" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Buddy"
                               Foreground="#F5F7FB"
                               FontSize="25"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="AppStatusTextBlock"
                               Text="Ready"
                               Foreground="#9AA4B5"
                               FontSize="13"
                               Margin="0,4,0,0" />
                </StackPanel>

                <Border x:Name="StatusDot"
                        Grid.Column="1"
                        Width="12"
                        Height="12"
                        Background="#36D399"
                        CornerRadius="6"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,8,2,0" />
            </Grid>

            <Border Grid.Row="1"
                    Background="#1B1F27"
                    BorderBrush="#2A303A"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="16"
                    Margin="0,24,0,24">
                <Grid>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Text"
                                   Foreground="#D7DCE7"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center" />
                        <TextBlock x:Name="VoiceStateTextBlock"
                                   Text="Idle"
                                   Foreground="#8D97AA"
                                   FontSize="13"
                                   Margin="0,8,0,0"
                                   HorizontalAlignment="Center" />
                        <TextBlock x:Name="ShortcutStateTextBlock"
                                   Text="Ctrl + Alt + Space to type&#x0a;Ctrl + Alt + Esc to quit"
                                   Foreground="#5F6B7C"
                                   FontSize="12"
                                   Margin="0,14,0,0"
                                   MaxWidth="220"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   HorizontalAlignment="Center" />
                        <Border x:Name="AudioLevelTrack"
                                Width="180"
                                Height="6"
                                Background="#29303A"
                                CornerRadius="3"
                                Margin="0,18,0,0"
                                HorizontalAlignment="Center"
                                ClipToBounds="True">
                            <Border x:Name="AudioLevelFill"
                                    Width="0"
                                    Height="6"
                                    Background="#2B7CFF"
                                    CornerRadius="3"
                                    HorizontalAlignment="Left" />
                        </Border>
                        <TextBlock x:Name="CaptureDetailTextBlock"
                                   Text="Voice is off for now"
                                   Foreground="#5F6B7C"
                                   FontSize="11"
                                   Margin="0,10,0,0"
                                   MaxWidth="220"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="You"
                                   Foreground="#6B7585"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Margin="0,16,0,6"
                                   HorizontalAlignment="Center" />
                        <Border Background="#141922"
                                BorderBrush="#27303A"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="10"
                                Width="228"
                                MinHeight="64"
                                MaxHeight="86">
                            <TextBlock x:Name="TranscriptTextBlock"
                                       Text="Prompt will appear here"
                                       Foreground="#8D97AA"
                                       FontSize="12"
                                       LineHeight="16"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       TextTrimming="CharacterEllipsis" />
                        </Border>
                        <TextBlock Text="Buddy"
                                   Foreground="#6B7585"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Margin="0,12,0,6"
                                   HorizontalAlignment="Center" />
                        <Border Background="#141922"
                                BorderBrush="#27303A"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="10"
                                Width="228"
                                MinHeight="78"
                                MaxHeight="128">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <TextBlock x:Name="ClaudeResponseTextBlock"
                                           Text="Response will appear here"
                                           Foreground="#D7DCE7"
                                           FontSize="12"
                                           LineHeight="16"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap" />
                            </ScrollViewer>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <Button Grid.Row="2"
                    Content="Quit"
                    Click="HandleQuitButtonClick"
                    Style="{StaticResource PanelButtonStyle}" />
        </Grid>
    </Border>
</Window>
