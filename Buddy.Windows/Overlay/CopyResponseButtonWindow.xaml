<Window x:Class="Buddy.Windows.Overlay.CopyResponseButtonWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Buddy Copy"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowActivated="False"
        ShowInTaskbar="False"
        Topmost="True"
        SizeToContent="WidthAndHeight"
        UseLayoutRounding="True">
    <Border x:Name="ButtonBorder"
            Background="#E614171C"
            BorderBrush="#663F4856"
            BorderThickness="1"
            CornerRadius="8"
            Padding="0">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20"
                              Color="#000000"
                              Opacity="0.45"
                              ShadowDepth="6" />
        </Border.Effect>
        <Button x:Name="CopyButton"
                Padding="12,7"
                Background="Transparent"
                BorderBrush="Transparent"
                BorderThickness="0"
                Cursor="Hand"
                Click="HandleCopyButtonClick"
                ToolTip="Copy the response to clipboard">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Button.Template>
            <StackPanel Orientation="Horizontal">
                <Path Data="M 4,4 L 4,14 L 12,14 L 12,4 Z M 6,2 L 14,2 L 14,12"
                      Stroke="#7FB6FF"
                      StrokeThickness="1.4"
                      Fill="Transparent"
                      Width="16"
                      Height="16"
                      VerticalAlignment="Center"
                      StrokeLineJoin="Round" />
                <TextBlock x:Name="CopyButtonLabel"
                           Text="Copy"
                           Foreground="#D7DCE7"
                           FontSize="12"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="7,0,0,0" />
            </StackPanel>
        </Button>
    </Border>
</Window>
